generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AccountType {
  SAVINGS
  CHECKING
  CREDIT_CARD
  INVESTMENT
  CASH
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum AssetType {
  STOCK
  MUTUAL_FUND
  SIP
  CRYPTO
  ETF
  FIXED_DEPOSIT
  RECURRING_DEPOSIT
  REAL_ESTATE
  GOLD
  GOLD_SCHEME
  VEHICLE
  OTHER
}

enum LoanType {
  HOME
  CAR
  PERSONAL
  EDUCATION
  BUSINESS
  OTHER
}

enum P2PType {
  LENT
  BORROWED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum BillFrequency {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
  EVERY_2_MONTHS
  QUARTERLY
  EVERY_4_MONTHS
  HALF_YEARLY
  YEARLY
  CUSTOM
}

enum BillStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum BillOccurrenceStatus {
  PAID
  SKIPPED
}

enum GoalType {
  FARM_HOUSE
  EMERGENCY_FUND
  RELOCATION
  CAR_PURCHASE
  RETIREMENT
  TRAVEL
  EDUCATION
  CUSTOM
}

enum GoalPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum GoalRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum ContributionType {
  RECURRING
  ONE_TIME
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  currency     String   @default("INR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
  investments   Investment[]
  goals         Goal[]
  loans         Loan[]
  subscriptions Subscription[]
  recurringBills  RecurringBill[]
  billOccurrences BillOccurrence[]
  creditCards   CreditCard[]
  p2pLoans      P2PLoan[]
  cardEmis      CardEMI[]
  familyMembers FamilyMember[]
  refreshTokens RefreshToken[]
  budgets       Budget[]
  investmentSnapshots InvestmentSnapshot[]
  goalContributions   GoalContribution[]

  @@map("users")
}

model FamilyMember {
  id        String   @id @default(cuid())
  userId    String
  name      String
  relation  String?
  color     String?
  emoji     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownedAccounts     Account[]
  transactions      Transaction[]  @relation("TxnPrimary")
  splitTransactions Transaction[]  @relation("TxnSplit")
  investments       Investment[]   @relation("InvPrimary")
  splitInvestments  Investment[]   @relation("InvSplit")
  loans             Loan[]         @relation("LoanBorrower")
  loanPayments      Loan[]         @relation("LoanPayer")
  creditCards       CreditCard[]
  p2pLoans          P2PLoan[]
  subscriptions     Subscription[]
  recurringBills    RecurringBill[]
  cardEmis          CardEMI[]
  goals             Goal[]

  @@index([userId])
  @@map("family_members")
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  memberId  String?
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(14, 2)
  currency  String      @default("INR")
  color     String?
  icon      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  member       FamilyMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  transactions   Transaction[]
  investments    Investment[]    @relation("InvestmentBankAccount")
  loans          Loan[]          @relation("LoanBankAccount")
  goalsFunded    Goal[]          @relation("GoalFundingAccount")
  recurringBills RecurringBill[] @relation("BillAccount")

  @@index([userId])
  @@index([memberId])
  @@map("accounts")
}

model Category {
  id        String          @id @default(cuid())
  userId    String?
  name      String
  icon      String?
  color     String?
  type      TransactionType
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@map("categories")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  accountId      String?
  categoryId     String?
  memberId       String?
  splitMemberId  String?
  splitRatio     Decimal?  @default(50) @db.Decimal(5, 2) // % that goes to memberId; rest to splitMemberId
  type           TransactionType
  amount         Decimal   @db.Decimal(14, 2)
  description    String?
  notes          String?
  date           DateTime
  isRecurring    Boolean   @default(false)
  // True for the principal portion of an EMI on a loan linked to an asset --
  // still real cash leaving the account (kept as type EXPENSE for balance
  // accounting), but excluded from expense analytics: it builds equity, not spend.
  isWealthTransfer Boolean @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  member      FamilyMember?  @relation("TxnPrimary",  fields: [memberId],      references: [id], onDelete: SetNull)
  splitMember FamilyMember?  @relation("TxnSplit",    fields: [splitMemberId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, type])
  @@index([categoryId])
  @@index([memberId])
  @@map("transactions")
}

model Investment {
  id           String    @id @default(cuid())
  userId       String
  assetName    String
  assetType    AssetType
  ticker       String?
  quantity     Decimal   @default(0) @db.Decimal(18, 6)
  buyPrice     Decimal   @default(0) @db.Decimal(14, 2)
  currentPrice Decimal   @default(0) @db.Decimal(14, 2)
  purchaseDate DateTime
  exchange     String?
  notes        String?

  // SIP / Mutual Fund
  monthlyAmount Decimal? @db.Decimal(14, 2)   // monthly SIP / RD / gold scheme installment
  fundCategory  String?                         // Equity, Debt, Hybrid, ELSS, Index
  folioNumber   String?                         // MF / SIP folio number

  // Recurring Deposit & Fixed Deposit & Gold Scheme
  maturityDate   DateTime?
  maturityAmount Decimal?  @db.Decimal(14, 2)
  interestRate   Decimal?  @db.Decimal(5, 2)

  // Common
  platform       String?
  memberId       String?    // primary owner
  splitMemberId  String?    // secondary owner (for split investments)
  splitRatio     Decimal?   @default(50) @db.Decimal(5, 2) // % primary member owns; rest to splitMember
  bankAccountId  String?

  // Collateral assets (Real Estate / Vehicle) that may back a Loan --
  // ownership/appreciation only meaningful for those types, but kept as
  // plain nullable columns on this table rather than a separate Property
  // model, same as SIP/RD-specific fields above.
  address                  String?
  ownershipPercent         Decimal?  @db.Decimal(5, 2)
  expectedAppreciationRate Decimal?  @db.Decimal(5, 2) // % p.a., for projected valuation

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  member      FamilyMember?  @relation("InvPrimary", fields: [memberId],      references: [id], onDelete: SetNull)
  splitMember FamilyMember?  @relation("InvSplit",   fields: [splitMemberId], references: [id], onDelete: SetNull)
  bankAccount Account?       @relation("InvestmentBankAccount", fields: [bankAccountId], references: [id], onDelete: SetNull)
  linkedLoans Loan[]         @relation("LoanCollateral")

  @@index([userId])
  @@index([userId, assetType])
  @@index([memberId])
  @@map("investments")
}

model Goal {
  id            String       @id @default(cuid())
  userId        String
  memberId      String?
  name          String
  description   String?
  icon          String?
  color         String?
  goalType      GoalType     @default(CUSTOM)
  priority      GoalPriority @default(MEDIUM)
  status        GoalStatus   @default(ACTIVE)
  targetAmount  Decimal      @db.Decimal(14, 2)
  currentAmount Decimal      @default(0) @db.Decimal(14, 2)
  targetDate    DateTime

  // Planning inputs -- everything the intelligence engine reasons over
  monthlyContribution   Decimal?       @db.Decimal(14, 2) // planned recurring contribution
  expectedReturnRate    Decimal?       @db.Decimal(5, 2)  // % p.a., for growth projection
  expectedInflationRate Decimal?       @db.Decimal(5, 2)  // % p.a., for real-value projection
  riskLevel             GoalRiskLevel?
  fundingAccountId      String?        // which account funds this goal
  notes                 String?

  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  member         FamilyMember?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  fundingAccount Account?           @relation("GoalFundingAccount", fields: [fundingAccountId], references: [id], onDelete: SetNull)
  contributions  GoalContribution[]

  @@index([userId])
  @@index([memberId])
  @@map("goals")
}

model GoalContribution {
  id        String           @id @default(cuid())
  goalId    String
  userId    String
  amount    Decimal          @db.Decimal(14, 2)
  date      DateTime
  type      ContributionType @default(ONE_TIME)
  notes     String?
  createdAt DateTime         @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([userId])
  @@map("goal_contributions")
}

model Loan {
  id               String   @id @default(cuid())
  userId           String
  memberId         String?  // who is the borrower
  payerMemberId    String?  // who pays the EMI (may differ from borrower)
  bankAccountId    String?  // which account the loan is linked to
  linkedInvestmentId String? // collateral asset this loan funded (Property, Vehicle, ...) -- EMI principal builds its equity instead of counting as an expense
  name             String
  loanType         LoanType
  principal        Decimal  @db.Decimal(14, 2)
  interestRate     Decimal  @db.Decimal(5, 2)
  emi              Decimal  @db.Decimal(14, 2)
  remainingBalance Decimal  @db.Decimal(14, 2)
  tenureMonths     Int
  startDate        DateTime
  lender           String?
  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  member           FamilyMember?  @relation("LoanBorrower", fields: [memberId], references: [id], onDelete: SetNull)
  payer            FamilyMember?  @relation("LoanPayer",    fields: [payerMemberId], references: [id], onDelete: SetNull)
  bankAccount      Account?       @relation("LoanBankAccount", fields: [bankAccountId], references: [id], onDelete: SetNull)
  linkedInvestment Investment?    @relation("LoanCollateral", fields: [linkedInvestmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([memberId])
  @@index([linkedInvestmentId])
  @@map("loans")
}

// DEPRECATED: superseded by RecurringBill. Kept in the schema so `prisma db push`
// doesn't drop the table (and its data) before the one-time migration script
// (src/scripts/migrateSubscriptionsToBills.ts) has copied every row across.
// Safe to delete this model once the migration has been run and verified.
model Subscription {
  id          String       @id @default(cuid())
  userId      String
  memberId    String?
  serviceName String
  amount      Decimal      @db.Decimal(10, 2)
  billingCycle BillingCycle
  renewalDate DateTime
  category    String?
  url         String?
  notes       String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  member FamilyMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, renewalDate])
  @@index([memberId])
  @@map("subscriptions")
}

// ─── Recurring Bills & Commitments ───────────────────────────────────────────
//
// A RecurringBill is the *definition* of a commitment (Netflix, rent, insurance
// premium, gym...). Future occurrences are never stored -- they are projected on
// the fly from (startDate, frequency, endDate) by lib/billSchedule.ts. Only
// *materialized events* (an occurrence the user paid or explicitly skipped) get
// a BillOccurrence row. This keeps the schema normalized, makes month-skipping
// non-destructive, and lets forecasts extend arbitrarily far without row bloat.

model RecurringBill {
  id       String  @id @default(cuid())
  userId   String
  memberId String?

  name     String
  vendor   String? // who gets paid: "Netflix", "Airtel", "LIC", landlord's name...
  category String  @default("Other") // free-form -- unlimited categories, suggested list lives in shared constants
  icon     String?
  color    String?

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("INR")

  frequency          BillFrequency @default(MONTHLY)
  customIntervalDays Int? // only for frequency = CUSTOM: repeat every N days

  startDate DateTime // anchor: the first due date; day-of-month is the anchor day for monthly-family cycles
  endDate   DateTime? // optional: no occurrences projected after this

  reminderDays  Int     @default(3) // notify N days before each due date
  autoDebit     Boolean @default(false)
  paymentMethod String? // UPI, Debit Card, Credit Card, Net Banking, Cash...
  accountId     String? // bank account the bill is debited from
  creditCardId  String? // or the credit card it's charged to

  status      BillStatus @default(ACTIVE)
  pausedUntil DateTime? // PAUSED + date = auto-resume after; PAUSED + null = until manually resumed

  url   String?
  notes String?
  tags  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  member      FamilyMember?    @relation(fields: [memberId], references: [id], onDelete: SetNull)
  account     Account?         @relation("BillAccount", fields: [accountId], references: [id], onDelete: SetNull)
  creditCard  CreditCard?      @relation("BillCreditCard", fields: [creditCardId], references: [id], onDelete: SetNull)
  occurrences BillOccurrence[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, category])
  @@index([memberId])
  @@map("recurring_bills")
}

model BillOccurrence {
  id     String @id @default(cuid())
  billId String
  userId String

  dueDate DateTime // the scheduled occurrence this event refers to (unique per bill)
  status  BillOccurrenceStatus

  // PAID-only fields
  amount        Decimal?  @db.Decimal(12, 2) // what was actually paid (may differ from the bill's amount)
  paidDate      DateTime?
  transactionId String? // expense Transaction created for this payment, so undo can reverse it

  notes     String?
  createdAt DateTime @default(now())

  bill RecurringBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([billId, dueDate])
  @@index([userId, dueDate])
  @@index([billId])
  @@map("bill_occurrences")
}

model CreditCard {
  id             String   @id @default(cuid())
  userId         String
  memberId       String?
  cardName       String
  bank           String?
  lastFourDigits String?
  creditLimit    Decimal  @db.Decimal(12, 2)
  outstanding    Decimal  @default(0) @db.Decimal(12, 2)
  minimumPayment Decimal? @db.Decimal(10, 2)
  dueDate        DateTime
  statementDate  DateTime?
  interestRate   Decimal? @db.Decimal(5, 2)
  color          String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  member         FamilyMember?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  cardEmis       CardEMI[]
  recurringBills RecurringBill[] @relation("BillCreditCard")

  @@index([userId])
  @@map("credit_cards")
}

model CardEMI {
  id           String   @id @default(cuid())
  userId       String
  creditCardId String
  memberId     String?
  itemName     String
  totalAmount  Decimal  @db.Decimal(12, 2)
  emiAmount    Decimal  @db.Decimal(10, 2)
  tenureMonths Int
  emisPaid     Int      @default(0)
  isNoCost     Boolean  @default(true)
  interestRate Decimal? @db.Decimal(5, 2)
  startDate    DateTime
  notes        String?
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard CreditCard     @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  member     FamilyMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([creditCardId])
  @@index([memberId])
  @@map("card_emis")
}

model P2PLoan {
  id              String   @id @default(cuid())
  userId          String
  memberId        String?
  personName      String
  type            P2PType
  amount          Decimal  @db.Decimal(12, 2)
  remainingAmount Decimal  @db.Decimal(12, 2)
  date            DateTime
  dueDate         DateTime?
  description     String?
  notes           String?
  isSettled       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  member FamilyMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([memberId])
  @@map("p2p_loans")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // SHA-256 hash, never the raw token -- defense in depth if the DB leaks
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model InvestmentSnapshot {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @db.Date // one row per user per calendar day
  totalInvested Decimal  @db.Decimal(14, 2)
  totalCurrent  Decimal  @db.Decimal(14, 2)
  totalPnl      Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("investment_snapshots")
}

model Budget {
  id           String   @id @default(cuid())
  userId       String
  categoryId   String
  monthlyLimit Decimal  @db.Decimal(14, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
  @@map("budgets")
}
